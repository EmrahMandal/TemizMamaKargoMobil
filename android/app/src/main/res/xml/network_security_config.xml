<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Debug builds: trust system + user-installed CAs (covers emulator CA store gaps) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <!-- Base config for all connections -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Keycloak domain: explicitly trust system + user CAs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">giris.temizmama.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Development servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.10.10.123</domain>
    </domain-config>

</network-security-config>
